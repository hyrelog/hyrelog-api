{
  "family": "hyrelog-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/hyrelogApiTaskRole",
  "containerDefinitions": [
    {
      "name": "hyrelog-api",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/hyrelog-api:IMAGE_TAG",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "LOG_LEVEL", "value": "info" },
        { "name": "DEFAULT_DATA_REGION", "value": "US" },
        { "name": "S3_REGION", "value": "us-east-1" },
        { "name": "S3_FORCE_PATH_STYLE", "value": "false" },
        { "name": "S3_BUCKET_US", "value": "REPLACE_HYRELOG_ARCHIVE_US" },
        { "name": "S3_BUCKET_EU", "value": "REPLACE_HYRELOG_ARCHIVE_EU" },
        { "name": "S3_BUCKET_UK", "value": "REPLACE_HYRELOG_ARCHIVE_UK" },
        { "name": "S3_BUCKET_AU", "value": "REPLACE_HYRELOG_ARCHIVE_AU" },
        { "name": "DASHBOARD_USAGE_URL", "value": "https://app.hyrelog.com" }
      ],
      "secrets": [
        { "name": "INTERNAL_TOKEN", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/INTERNAL_TOKEN" },
        { "name": "API_KEY_SECRET", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/API_KEY_SECRET" },
        { "name": "DASHBOARD_SERVICE_TOKEN", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/DASHBOARD_SERVICE_TOKEN" },
        { "name": "WEBHOOK_SECRET_ENCRYPTION_KEY", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/WEBHOOK_SECRET_ENCRYPTION_KEY" },
        { "name": "DATABASE_URL_US", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/DATABASE_URL_US" },
        { "name": "DATABASE_URL_EU", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/DATABASE_URL_EU" },
        { "name": "DATABASE_URL_UK", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/DATABASE_URL_UK" },
        { "name": "DATABASE_URL_AU", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/DATABASE_URL_AU" },
        { "name": "S3_ACCESS_KEY_ID", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/S3_ACCESS_KEY_ID" },
        { "name": "S3_SECRET_ACCESS_KEY", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/S3_SECRET_ACCESS_KEY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hyrelog-api",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "node -e \"require('http').get('http://127.0.0.1:3000/health',r=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
