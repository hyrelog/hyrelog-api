{
  "family": "hyrelog-dashboard",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/hyrelogDashboardTaskRole",
  "containerDefinitions": [
    {
      "name": "hyrelog-dashboard",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/hyrelog-dashboard:IMAGE_TAG",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "NEXT_PUBLIC_APP_URL", "value": "https://app.hyrelog.com" },
        { "name": "HYRELOG_API_URL", "value": "https://api.hyrelog.com" },
        { "name": "NEXT_PUBLIC_API_BASE_URL", "value": "https://api.hyrelog.com" },
        { "name": "BETTER_AUTH_URL", "value": "https://app.hyrelog.com" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/DASHBOARD_DATABASE_URL" },
        { "name": "BETTER_AUTH_SECRET", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/BETTER_AUTH_SECRET" },
        { "name": "DASHBOARD_SERVICE_TOKEN", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/DASHBOARD_SERVICE_TOKEN" },
        { "name": "HYRELOG_API_KEY_SECRET", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:hyrelog/HYRELOG_API_KEY_SECRET" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hyrelog-dashboard",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
